                        }
                      ],
                      "CURRENT_AMPL_W": [
                        {
                          "name": "ML34",
                          "help": {},
                          "cost": 0
                        }
                      ]
                    },
                    "shuntResistor": 0.02,
                    "amplifyingNetworkImax": 5,
                    "amplifyingNetworkVm": 3.3,
                    "amplifyingNetworkPrating": 1.4,
                    "opAmpGain": 2,
                    "offsetNetworkAttenuation": 0.765,
                    "polarizationOffset": 1.559,
                    "metaData": [
                      {
                        "type": "OpAmp",
                        "partNumber": "TSV994"
                      }
                    ],
                    "cost": 0
                  }
                ],
                "tRise": 1000
              },
