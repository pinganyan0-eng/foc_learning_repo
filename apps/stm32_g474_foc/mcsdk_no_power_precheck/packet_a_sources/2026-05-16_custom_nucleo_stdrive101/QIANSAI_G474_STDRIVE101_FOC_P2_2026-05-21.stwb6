    "power": [
      {
        "hardwareFamily": "POWER",
        "id": "user.MY-STDRIVE101_POWER_BOARD",
        "label": "MY-STDRIVE101_POWER_BOARD",
        "description": "Custom 24V three-phase BLDC/PMSM power board based on STDRIVE101 gate driver. The board uses six external MOSFETs, three low-side shunt resistors for current sensing, Hall sensor inputs, and nFAULT protection. It is intended to be used with NUCLEO-G474RE and STM32 MCSDK FOC projects.",
        "compatibility": [
          "FOC",
          "sixStep"
        ],
        "descVersion": 4,
        "contentVersion": "1.0",
        "motorDrives": [
          {
            "name": "M1",
            "minRatedVoltage": 12,
            "maxRatedVoltage": 24,
            "maxRatedCurrent": 5,
            "maxRatedPower": 120,
            "resistorOffset": 0,
            "connectorType": "morpho",
            "features": [
              {
                "type": "CurrentSensing",
