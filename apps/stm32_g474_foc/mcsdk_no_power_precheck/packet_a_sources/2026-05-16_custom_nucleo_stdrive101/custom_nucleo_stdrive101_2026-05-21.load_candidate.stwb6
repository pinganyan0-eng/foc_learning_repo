                      "power":  [
                                    {
                                        "hardwareFamily":  "POWER",
                                        "id":  "QS_TIM1_OPAMP_PWR",
                                        "label":  "QS_TIM1_OPAMP_PWR",
                                        "description":  "Short-name no-power alias for the QIANSAI STDRIVE101 TIM1 OPAMP adapter candidate. It uses TIM1 complementary PWM and STM32G474 internal OPAMP/PGA current-sense candidate pins. This is not the current PCB2 as-built route; it requires adapter, flying-wire, or PCB rework and conflicts with the current PCB2 PA1 Hall clue.",
                                        "compatibility":  [
                                                              "FOC",
                                                              "sixStep"
                                                          ],
                                        "connectorTypes":  [
                                                               "morpho"
                                                           ],
                                        "descVersion":  4,
                                        "contentVersion":  "1.0",
                                        "motorDrives":  [
                                                            {
                                                                "name":  "M1",
                                                                "connectorType":  "morpho",
                                                                "minRatedVoltage":  12,
                                                                "maxRatedVoltage":  24,
                                                                "maxRatedCurrent":  5,
                                                                "maxRatedPower":  120,
                                                                "resistorOffset":  0,
                                                                "features":  [
                                                                                 {
                                                                                     "type":  "CurrentSensing",
                                                                                     "name":  "CurrentSensing",
                                                                                     "tRise":  1000,
                                                                                     "hwVariants":  [
                                                                                                        {
                                                                                                            "type":  "ThreeShunt_RawCurrents_SingleEnded",
                                                                                                            "help":  {
                                                                                                                         "en":  "No-power internal OPAMP/PGA candidate only. Routes current U/V/W to PA1/PA7/PB0 through NUCLEO morpho pins; requires adapter, flying-wire, or PCB rework before any hardware use."
                                                                                                                     },
                                                                                                            "signals":  {
                                                                                                                            "CURRENT_SHUNT_UP":  [
                                                                                                                                                     {
                                                                                                                                                         "name":  "ML30",
                                                                                                                                                         "help":  {
                                                                                                                                                                      "en":  "Internal OPAMP candidate: PA1 / OPAMP1 VINP on CN7.30. Conflicts with current PCB2 PA1 Hall clue."
                                                                                                                                                                  },
                                                                                                                                                         "cost":  0
                                                                                                                                                     }
                                                                                                                                                 ],
                                                                                                                            "CURRENT_SHUNT_VP":  [
                                                                                                                                                     {
                                                                                                                                                         "name":  "MR15",
                                                                                                                                                         "help":  {
                                                                                                                                                                      "en":  "Internal OPAMP candidate: PA7 / OPAMP1-OPAMP2 VINP on CN10.15."
                                                                                                                                                                  },
                                                                                                                                                         "cost":  0
                                                                                                                                                     }
